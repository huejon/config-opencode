{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "opencode-go/minimax-m3",
  "default_agent": "work",
  "share": "disabled",
  "permission": {
    "*": "allow",
    "question": "deny",
    "doom_loop": "allow",
    "bash": {
      "*": "allow",
      "*deploy*": "deny",
      "*terraform apply*": "deny",
      "*kubectl apply*": "deny",
      "*docker push*": "deny",
      "*npm publish*": "deny",
      "*pnpm publish*": "deny",
      "curl * | sh": "deny",
      "curl * | bash": "deny",
      "wget * | sh": "deny",
      "wget * | bash": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  }
}
